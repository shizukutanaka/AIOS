{
  "dashboard": {
    "title": "aictl — AI Inference Dashboard",
    "uid": "aios-inference",
    "tags": ["aictl", "inference", "llm"],
    "timezone": "browser",
    "refresh": "10s",
    "panels": [
      {
        "title": "Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(vllm:request_success_total[5m])",
            "legendFormat": "vLLM success/s"
          },
          {
            "expr": "rate(sglang_request_success_total[5m])",
            "legendFormat": "SGLang success/s"
          }
        ]
      },
      {
        "title": "TTFT (Time to First Token) p95",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(vllm:time_to_first_token_seconds_bucket[5m]))",
            "legendFormat": "vLLM TTFT p95"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.5, "color": "yellow"},
                {"value": 2, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "title": "KV Cache Utilization",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "vllm:gpu_cache_usage_perc",
            "legendFormat": "KV Cache %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.7, "color": "yellow"},
                {"value": 0.9, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "title": "Active Requests",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 8},
        "targets": [
          {
            "expr": "vllm:num_requests_running",
            "legendFormat": "Running"
          },
          {
            "expr": "vllm:num_requests_waiting",
            "legendFormat": "Waiting"
          }
        ]
      },
      {
        "title": "Token Throughput",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(vllm:generation_tokens_total[5m])",
            "legendFormat": "tokens/s"
          }
        ],
        "fieldConfig": {"defaults": {"unit": "ops"}}
      },
      {
        "title": "GPU Memory (VRAM)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "DCGM_FI_DEV_FB_USED",
            "legendFormat": "Used MB"
          },
          {
            "expr": "DCGM_FI_DEV_FB_FREE",
            "legendFormat": "Free MB"
          }
        ],
        "fieldConfig": {"defaults": {"unit": "decmbytes"}}
      },
      {
        "title": "System Pressure (PSI)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "aios_psi_memory_some_avg10",
            "legendFormat": "Memory pressure"
          },
          {
            "expr": "aios_psi_cpu_some_avg10",
            "legendFormat": "CPU pressure"
          },
          {
            "expr": "aios_psi_io_some_avg10",
            "legendFormat": "IO pressure"
          }
        ],
        "fieldConfig": {"defaults": {"unit": "percent"}}
      }
    ],
    "templating": {
      "list": [
        {
          "name": "instance",
          "type": "query",
          "query": "label_values(vllm:num_requests_running, instance)",
          "refresh": 2
        }
      ]
    }
  }
}
