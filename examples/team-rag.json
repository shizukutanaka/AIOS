{
  "name": "team-rag",
  "version": "1",
  "services": [
    {
      "name": "llm",
      "runtime": "vllm",
      "model": "meta-llama/Llama-3.2-8B-Instruct",
      "port": 8000,
      "gpu_required": true,
      "gpu_memory_mb": 16384
    },
    {
      "name": "embedding",
      "runtime": "ollama",
      "model": "nomic-embed-text",
      "port": 11435
    },
    {
      "name": "webui",
      "image": "ghcr.io/open-webui/open-webui:main",
      "port": 3000,
      "env": {"OPENAI_API_BASE_URL": "http://localhost:8000/v1"}
    }
  ],
  "trust_policy": "warn"
}
