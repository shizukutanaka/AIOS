{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(python3 -m unittest*)",
      "Bash(python3 -m aictl*)",
      "Bash(python3 -m py_compile*)",
      "Bash(find * -name*)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(pip install*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m py_compile \"$CLAUDE_FILE_PATHS\" 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd $CLAUDE_PROJECT_DIR && python3 -m unittest discover -s tests -q 2>&1 | tail -3"
          }
        ]
      }
    ]
  }
}
